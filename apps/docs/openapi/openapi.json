{
  "openapi": "3.0.3",
  "info": {
    "title": "BasePillar API",
    "version": "1.0.0",
    "description": "OpenAPI specification for BasePillar."
  },
  "servers": [
    {
      "url": "/api"
    }
  ],
  "paths": {
    "/auth/register": {
      "post": {
        "summary": "Register",
        "tags": ["Auth"],
        "responses": {
          "201": {
            "description": "User registered"
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "summary": "Login",
        "tags": ["Auth"],
        "responses": {
          "200": {
            "description": "Login successful"
          }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "summary": "Logout",
        "tags": ["Auth"],
        "responses": {
          "200": {
            "description": "Logout successful"
          }
        }
      }
    },
    "/auth/me": {
      "get": {
        "summary": "Current user",
        "tags": ["Auth"],
        "responses": {
          "200": {
            "description": "Current user"
          }
        }
      }
    }
  }
}
