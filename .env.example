# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/basepillar
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=basepillar

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=21d

# Frontend
FRONTEND_URL=http://localhost,http://localhost:5173
VITE_API_PROXY_TARGET=http://localhost:3000
VITE_DOCS_PROXY_TARGET=http://localhost:3001
OPENAPI_SOURCE_URL=http://localhost:3000/api/docs-json

# Centralized Console URL (The web app that receives logs)
CENTRALIZED_CONSOLE_URL=http://localhost:4000

# Garage S3 Storage
S3_ENDPOINT=http://localhost:3900
S3_ACCESS_KEY_ID=GK_ACCESS_KEY
S3_SECRET_ACCESS_KEY=GK_SECRET_KEY
S3_BUCKET=basepillar-storage
S3_REGION=garage

# Node Environment
NODE_ENV=development
